# -----------------------------------------------------------------------------
# Brimble pipeline monorepo — ignore local deps, builds, secrets, and caches.
# Verify a path: git check-ignore -v path/to/file
# Untracked but not ignored: git ls-files -o --exclude-standard
# -----------------------------------------------------------------------------

# Dependencies (any package root)
node_modules/

# TypeScript / tooling
*.tsbuildinfo
.turbo/

# Build output (any directory named dist or build)
dist/
build/

# Test / coverage
coverage/
.nyc_output/

# Env and secrets (keep .env.example tracked)
.env
.env.*.local
.env.local

# Logs and temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/tmp/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Explicit monorepo paths (redundant with rules above; helps tools and humans)
# -----------------------------------------------------------------------------
backend/node_modules/
backend/dist/
backend/coverage/

frontend/node_modules/
frontend/dist/
frontend/coverage/

# If someone runs npm install inside the sample app
sample-app/node_modules/

# Prevent accidental commit of emitted JS next to TS sources (if tsc outDir changes)
backend/src/**/*.js
frontend/src/**/*.js

# Vite / Vitest caches under package trees
**/.vite/
**/.vite-temp/

# Optional local artifacts
*.swp
*.swo

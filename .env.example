POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/brimble
POSTGRES_DB=brimble
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PORT=3000
RAILPACK_BIN=/usr/local/bin/railpack
RAILPACK_VERSION=v0.23.0
CADDY_ADMIN_URL=http://caddy:2019
API_URL=http://backend:3000

# Docker Compose + Caddy wiring (copy to `.env` and adjust as needed)
CADDY_HTTP_PORT=80
CADDY_ADMIN_PORT=2019

# Caddyfile env substitution (loaded into the `caddy` container)
CADDY_SITE_ADDRESS=:80
CADDY_ADMIN_LISTEN_ADDR=0.0.0.0:2019
CADDY_BACKEND_UPSTREAM=backend:3000
CADDY_FRONTEND_UPSTREAM=frontend:5173

# Backend container user + docker socket access (Linux)
# Find your host socket group id with:
#   stat -c '%g' /var/run/docker.sock
DOCKER_SOCK_GID=0
APP_UID=10001
APP_GID=10001

# Frontend container user (runtime)
FRONTEND_APP_UID=10002
FRONTEND_APP_GID=10002
